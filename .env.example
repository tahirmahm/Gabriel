# ─── Optional API Keys ──────────────────────────────────────────────────────
# All keys are OPTIONAL. The dashboard works without them using public endpoints.

# Google Maps API Key (enables photorealistic Google 3D Tiles in the globe)
# Get yours: https://console.cloud.google.com → APIs → Map Tiles API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cesium Ion Access Token (optional – for terrain + additional imagery layers)
# Get free token: https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# ADS-B Exchange RapidAPI Key (optional – enables military/special flight tracking)
# Get free tier: https://rapidapi.com/adsbx/api/adsbexchange-com1
ADSB_RAPIDAPI_KEY=

# OpenSky Network credentials (optional – raises rate limit from 400 to 4000 req/day)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
